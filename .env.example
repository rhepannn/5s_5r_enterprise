# ============================================================
# APP
# ============================================================
NODE_ENV=development          # production saat go-live
API_PORT=3001
FRONTEND_URL=http://localhost:5173   # ganti ke domain produksi/Vercel, mis. https://5s.vercel.app
# Untuk frontend & backend BEDA domain (Vercel + Railway/Render): set ke 'none'.
# Lokal/same-origin biarkan 'strict'. ('none' otomatis butuh HTTPS/secure.)
COOKIE_SAMESITE=strict

# ============================================================
# JWT  — WAJIB diganti untuk produksi!
# Buat secret acak: `openssl rand -hex 32` (minimal 32 karakter).
# Aplikasi akan MENOLAK start di production bila secret masih default/lemah.
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ============================================================
# DATABASE — pilih SALAH SATU opsi
# ------------------------------------------------------------
# OPSI A — Cloud (Supabase, disarankan; tanpa Docker DB)
#   DATABASE_URL = pooler (port 6543, pgbouncer) untuk runtime
#   DIRECT_URL   = koneksi langsung (port 5432) untuk migrasi/db push
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
#
# OPSI B — Self-host (docker-compose.prod.yml). Pakai nilai di bawah & set DATABASE_URL ke service 'postgres'.
POSTGRES_USER=5s_user
POSTGRES_PASSWORD=ganti_password_kuat
POSTGRES_DB=5s_enterprise
POSTGRES_PORT=5432
# DATABASE_URL=postgresql://5s_user:ganti_password_kuat@postgres:5432/5s_enterprise

# (Opsional) MongoDB untuk log/audit trail volume besar — hanya bila dipakai
MONGO_USER=5s_mongo
MONGO_PASSWORD=ganti_password_kuat
MONGODB_URL=

# ============================================================
# REDIS — cache leaderboard/dashboard + refresh token
# OPSI A — Upstash cloud (TLS): rediss://default:TOKEN@host:port
# OPSI B — Self-host: kosongkan REDIS_URL, pakai host/port/password
# ============================================================
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=ganti_password_kuat

# ============================================================
# STORAGE FOTO — Supabase Storage (disarankan)
# ============================================================
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxx
SUPABASE_STORAGE_BUCKET=5s-files

# (Alternatif self-host) MinIO — bila tidak pakai Supabase Storage
MINIO_ACCESS_KEY=5s_minio_access
MINIO_SECRET_KEY=ganti_password_kuat

# ============================================================
# EMAIL (Nodemailer) — reminder, digest, NC. Kosongkan utk nonaktif.
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password           # Gmail: App Password, bukan password akun
EMAIL_FROM=noreply@5s-enterprise.com

# ============================================================
# PUSH NOTIFICATION (Firebase Cloud Messaging) — opsional
# Pilih salah satu: path ke file JSON (disarankan) ATAU JSON inline
# ============================================================
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-sa.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# ============================================================
# WHATSAPP (opsional) — aktif hanya bila kedua nilai diisi
# ============================================================
WA_API_URL=
WA_API_TOKEN=
